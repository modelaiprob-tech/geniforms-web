# ── Firebase (cliente) ─────────────────────────────────────────────────────────
# Firebase Console → Project settings → General → Your apps → SDK setup
PUBLIC_FIREBASE_API_KEY=AIzaSy...
PUBLIC_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=tu-proyecto
PUBLIC_FIREBASE_STORAGE_BUCKET=tu-proyecto.firebasestorage.app
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# ── Firebase Admin (servidor — nunca exponer al cliente) ───────────────────────
# Firebase Console → Project settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=tu-proyecto
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com
# Copia la privateKey del JSON descargado, reemplazando los saltos de línea por \n
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ── Google API (para el Picker y Gemini) ───────────────────────────────────────
PUBLIC_GOOGLE_API_KEY=AIzaSy...
GEMINI_API_KEY=AIzaSy...
