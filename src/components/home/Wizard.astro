  /* ── Box sizing reset (Astro scopes styles per-component, Base.astro reset doesn't cascade here) ── */
  .wiz-wrap *,
  .wiz-wrap *::before,
  .wiz-wrap *::after,
  .modal-card *,
  .modal-card *::before,
  .modal-card *::after { box-sizing: border-box; }

  /* ── Inputs ── */
  input[type="text"],
  input[type="number"],
  textarea,
  select {
    width: 100%;
    box-sizing: border-box;
    border: 1.5px solid #E5E7EB;
