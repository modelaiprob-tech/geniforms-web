// ── STEP 2B ───────────────────────────────────────────────────────────────────
(function initStep2b() {
  var inpTitle  = document.getElementById('inp-title-b');
  var inpPaste  = document.getElementById('inp-paste');
  var btnBack   = document.getElementById('btn2b-back');
  var btnNext   = document.getElementById('btn2b-next');
  var solHdr    = document.getElementById('sol-hdr');
  var solBody   = document.getElementById('sol-body');
  var uploadZone = document.getElementById('upload-zone');
  var fileInput  = document.getElementById('file-input');
  var fileNameEl = document.getElementById('upload-filename');
  var uploadWarn = document.getElementById('upload-warn');

  solHdr.addEventListener('click', function() {
    solHdr.classList.toggle('open');
    solBody.classList.toggle('open');
  });

  function validate() {
    var hasText = inpPaste.value.trim().length > 0;
    var hasFile = state.uploadedText.length > 0;
    btnNext.disabled = !(inpTitle.value.trim() && (hasText || hasFile));
  }
  inpTitle.addEventListener('input', validate);
  inpPaste.addEventListener('input', validate);

  uploadZone.addEventListener('click', function() { fileInput.click(); });
  uploadZone.addEventListener('keydown', function(e) { if (e.key === 'Enter' || e.key === ' ') fileInput.click(); });
  uploadZone.addEventListener('dragover', function(e) { e.preventDefault(); uploadZone.classList.add('drag-over'); });
  uploadZone.addEventListener('dragleave', function() { uploadZone.classList.remove('drag-over'); });
  uploadZone.addEventListener('drop', function(e) {
    e.preventDefault(); uploadZone.classList.remove('drag-over');
    if (e.dataTransfer.files.length) handleFile(e.dataTransfer.files[0]);
  });
  fileInput.addEventListener('change', function() {
    if (fileInput.files.length) handleFile(fileInput.files[0]);
  });

  function handleFile(file) {
    var ext = file.name.split('.').pop().toLowerCase();
    if (ext !== 'txt' && ext !== 'pdf' && ext !== 'docx') {
      uploadWarn.classList.remove('hidden');
      return;
    }
    uploadWarn.classList.add('hidden');

    function onText(text) {
      state.uploadedText = text;
      fileNameEl.textContent = file.name;
      fileNameEl.style.display = 'block';
      validate();
    }

    if (ext === 'txt') {
      var reader = new FileReader();
      reader.onload = function(ev) { onText(ev.target.result); };
      reader.readAsText(file);
    } else if (ext === 'pdf') {
      var reader = new FileReader();
      reader.onload = function(ev) {
        var typedArray = new Uint8Array(ev.target.result);
        if (typeof pdfjsLib === 'undefined') { uploadWarn.classList.remove('hidden'); return; }
        pdfjsLib.GlobalWorkerOptions.workerSrc =
          'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
        pdfjsLib.getDocument({ data: typedArray }).promise.then(function(pdf) {
          var pages = [];
          for (var i = 1; i <= pdf.numPages; i++) pages.push(i);
          return Promise.all(pages.map(function(n) {
            return pdf.getPage(n).then(function(page) {
              return page.getTextContent().then(function(tc) {
                return tc.items.map(function(item) { return item.str; }).join(' ');
              });
            });
          }));
        }).then(function(texts) { onText(texts.join('\n')); })
        .catch(function() { uploadWarn.classList.remove('hidden'); });
      };
      reader.readAsArrayBuffer(file);
    } else if (ext === 'docx') {
      var reader = new FileReader();
      reader.onload = function(ev) {
        if (typeof mammoth === 'undefined') { uploadWarn.classList.remove('hidden'); return; }
        mammoth.extractRawText({ arrayBuffer: ev.target.result })
          .then(function(result) { onText(result.value); })
          .catch(function() { uploadWarn.classList.remove('hidden'); });
      };
      reader.readAsArrayBuffer(file);
    }
  }

  btnBack.addEventListener('click', function() { showStep('step-1'); });
  btnNext.addEventListener('click', function() {
    state.title            = inpTitle.value.trim();
    state.pastedText       = inpPaste.value.trim();
    state.solucionarioText = document.getElementById('inp-solucionario').value.trim();
    showStep('step-3');
  });
})();

// ── STEP 3 ────────────────────────────────────────────────────────────────────
(function initStep3() {
  var totalNum    = document.getElementById('type-total-num');
  var shortWarn   = document.getElementById('short-warn');
  var keepasisCard = document.getElementById('keepasis-card');
  var btnBack     = document.getElementById('btn3-back');
  var btnNext     = document.getElementById('btn3-next');
  var btnKeepasis = document.getElementById('btn3-keepasis');

  var rows = {
    multiple_choice: { chk: document.getElementById('chk-mc'),    tc: document.getElementById('tc-mc'),    input: document.getElementById('inp-count-mc') },
    true_false:      { chk: document.getElementById('chk-vf'),    tc: document.getElementById('tc-vf'),    input: document.getElementById('inp-count-vf') },
    short_answer:    { chk: document.getElementById('chk-short'), tc: document.getElementById('tc-short'), input: document.getElementById('inp-count-short') },
    checkboxes:      { chk: document.getElementById('chk-cb'),    tc: document.getElementById('tc-cb'),    input: document.getElementById('inp-count-cb') }
  };

  function recalcTotal() {
    var total = 0;
    Object.keys(rows).forEach(function(k) {
      if (state.types[k].on) total += Math.max(0, parseInt(rows[k].input.value, 10) || 0);
    });
    totalNum.textContent = total;
    btnNext.disabled = total < 1;
    shortWarn.classList.toggle('hidden', !state.types.short_answer.on);
  }

  Object.keys(rows).forEach(function(k) {
    var row = rows[k];
    row.chk.addEventListener('click', function() {
      state.types[k].on = !state.types[k].on;
      row.chk.classList.toggle('checked', state.types[k].on);
      row.tc.classList.toggle('active', state.types[k].on);
      if (state.types[k].on && (parseInt(row.input.value, 10) || 0) === 0) row.input.value = 5;
      recalcTotal();
    });
    row.input.addEventListener('input', function() {
      state.types[k].count = Math.max(0, parseInt(row.input.value, 10) || 0);
      recalcTotal();
    });
  });

  btnBack.addEventListener('click', function() {
    showStep(state.mode === 'format' ? 'step-2b' : 'step-2a');
  });

  btnNext.addEventListener('click', function() {
    Object.keys(rows).forEach(function(k) {
      state.types[k].count = Math.max(0, parseInt(rows[k].input.value, 10) || 0);
    });
    showStep('step-4');
  });

  btnKeepasis.addEventListener('click', function() {
    state.keepAsIs = true;
    showStep('step-4');
  });

  // Show "keep as is" hint when in format mode and step becomes visible
  var observer = new MutationObserver(function() {
    var isFormat = state.mode === 'format';
    keepasisCard.classList.toggle('hidden', !isFormat);
    btnKeepasis.classList.toggle('hidden', !isFormat);
  });
  observer.observe(document.getElementById('step-3'), { attributes: true, attributeFilter: ['class'] });
})();

// ── STEP 4 ────────────────────────────────────────────────────────────────────
(function initStep4() {
  var btnBack    = document.getElementById('btn4-back');
  var btnNext    = document.getElementById('btn4-next');
  var solToggle  = document.getElementById('sol-toggle');

  solToggle.addEventListener('click', function() {
