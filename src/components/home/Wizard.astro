<style>
  /* ── Wizard wrapper ── */
  .wiz-wrap {
    padding: 32px 24px 64px;
    display: flex;
    justify-content: center;
  }

  .wiz {
    width: 100%;
    max-width: 580px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ── Progress ── */
  .wiz-progress {
    position: relative;
    margin-bottom: 28px;
  }

  .wiz-prog-track {
    height: 3px;
    background: #E5E7EB;
    border-radius: 2px;
    margin: 0 20px;
    position: relative;
    top: 13px;
    z-index: 0;
  }

  .wiz-prog-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--magenta));
    border-radius: 2px;
    transition: width 0.4s ease;
    width: 0%;
  }

  .wiz-prog-steps {
    display: flex;
    justify-content: space-between;
    position: relative;
    z-index: 1;
  }

  .wiz-prog-step {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #E5E7EB;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s, transform 0.2s;
  }

  .wiz-prog-step span {
    font-size: 11px;
    font-weight: 700;
    color: #9CA3AF;
    transition: color 0.3s;
  }

  .wiz-prog-step.active {
    background: var(--accent);
    transform: scale(1.1);
  }
  .wiz-prog-step.active span { color: #fff; }
  .wiz-prog-step.done { background: var(--accent); }
  .wiz-prog-step.done span { color: #fff; }

  /* ── Steps ── */
  .wiz-step { display: none; flex-direction: column; }
  .wiz-step.active { display: flex; }

  .wiz-body {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding-bottom: 20px;
  }

  .wiz-body--center {
    align-items: center;
    padding: 48px 0;
    text-align: center;
  }

  .wiz-footer {
    display: flex;
    gap: 10px;
    padding-top: 4px;
  }

  .wiz-footer--col {
    flex-direction: column;
  }

  .wiz-footer .btn-secondary { flex: 1; }
  .wiz-footer .btn-primary   { flex: 2; }

  /* ── Section title (same as extension) ── */
  .section-title {
    font-size: 20px;
    font-weight: 700;
    color: var(--text);
    line-height: 1.25;
