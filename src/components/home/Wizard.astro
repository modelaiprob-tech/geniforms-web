  });
})();

// ── GOOGLE PICKER API ─────────────────────────────────────────────────────────
function getDriveToken() {
  return localStorage.getItem('gf_google_token');
}

function driveExportDoc(fileId, mimeType) {
  var token = getDriveToken();
  if (!token) return Promise.reject(new Error('no_token'));

  var DOCX_MIME = 'application/vnd.openxmlformats-officedocument.wordprocessingml.document';
  var isGoogleDoc = mimeType === 'application/vnd.google-apps.document';
  var isDocx      = mimeType === DOCX_MIME;

  if (isGoogleDoc) {
    // Google Docs → exportar como texto plano
    var url = 'https://www.googleapis.com/drive/v3/files/' + fileId + '/export?mimeType=text%2Fplain';
    return fetch(url, { headers: { Authorization: 'Bearer ' + token } })
      .then(function(r) {
        if (!r.ok) return Promise.reject(new Error('Drive ' + r.status + ' al exportar el documento'));
        return r.text();
      });
  }

  if (isDocx) {
    // .docx nativo en Drive → descargar binario y parsear con mammoth
    var url = 'https://www.googleapis.com/drive/v3/files/' + fileId + '?alt=media';
    return fetch(url, { headers: { Authorization: 'Bearer ' + token } })
      .then(function(r) {
        if (!r.ok) return Promise.reject(new Error('Drive ' + r.status + ' al descargar el archivo'));
        return r.arrayBuffer();
      })
      .then(function(buf) {
        if (typeof mammoth === 'undefined') return Promise.reject(new Error('mammoth no cargado'));
        return mammoth.extractRawText({ arrayBuffer: buf }).then(function(result) { return result.value; });
      });
  }

  // texto plano y cualquier otro formato descargable
  var url = 'https://www.googleapis.com/drive/v3/files/' + fileId + '?alt=media';
  return fetch(url, { headers: { Authorization: 'Bearer ' + token } })
    .then(function(r) {
      if (!r.ok) return Promise.reject(new Error('Drive ' + r.status + ' al descargar el archivo'));
      return r.text();
    });
}

var _pickerLoaded = false;
function loadPickerApi() {
  return new Promise(function(resolve, reject) {
    if (_pickerLoaded) { resolve(); return; }
    if (!window.gapi) { reject(new Error('gapi_not_loaded')); return; }
    gapi.load('picker', {
      callback: function() { _pickerLoaded = true; resolve(); },
      onerror:  function() { reject(new Error('picker_load_failed')); }
    });
  });
}

// ── FOLDER PICKER (Step 4) ────────────────────────────────────────────────────
(function initFolderPicker() {
  var btnPick      = document.getElementById('btn-pick-folder');
  var folderNameEl = document.getElementById('drive-folder-name');

  btnPick.addEventListener('click', function() {
    var token = getDriveToken();
    if (!token) {
      document.getElementById('login-modal').classList.remove('hidden');
      return;
    }
    loadPickerApi().then(function() {
      var view = new google.picker.DocsView(google.picker.ViewId.FOLDERS)
        .setSelectFolderEnabled(true)
        .setIncludeFolders(true);
      new google.picker.PickerBuilder()
        .addView(view)
        .setOAuthToken(token)
        .setDeveloperKey(googleApiKey)
        .setTitle('Selecciona una carpeta de destino')
        .setCallback(function(data) {
          if (data[google.picker.Response.ACTION] === google.picker.Action.PICKED) {
            var doc = (data[google.picker.Response.DOCUMENTS] || data.docs)[0];
            state.folderId   = doc[google.picker.Document.ID];
            state.folderName = doc[google.picker.Document.NAME];
            folderNameEl.textContent = state.folderName;
          }
        })
        .build()
        .setVisible(true);
    }).catch(function() {
      alert(window.__t ? window.__t('err.picker') : 'Error al cargar Google Picker.');
    });
  });
})();

// ── FILE PICKER (Step 2A ref) ─────────────────────────────────────────────────
(function initFilePicker() {
  var btnPick    = document.getElementById('btn-pick-ref-file');
  var selectedEl = document.getElementById('ref-file-selected');
  var fileNameEl = document.getElementById('ref-file-name');

  btnPick.addEventListener('click', function() {
    var token = getDriveToken();
    if (!token) {
      document.getElementById('login-modal').classList.remove('hidden');
      return;
    }
    loadPickerApi().then(function() {
      var view = new google.picker.DocsView()
        .setMimeTypes('application/vnd.google-apps.document,text/plain,application/vnd.openxmlformats-officedocument.wordprocessingml.document')
        .setMode(google.picker.DocsViewMode.LIST)
        .setIncludeFolders(true);
      new google.picker.PickerBuilder()
        .addView(view)
        .setOAuthToken(token)
        .setDeveloperKey(googleApiKey)
        .setTitle('Selecciona un documento de referencia')
        .setCallback(function(data) {
          if (data[google.picker.Response.ACTION] === google.picker.Action.PICKED) {
            var doc = (data[google.picker.Response.DOCUMENTS] || data.docs)[0];
            btnPick.textContent = 'Cargando...';
            btnPick.disabled = true;
            driveExportDoc(doc[google.picker.Document.ID], doc[google.picker.Document.MIME_TYPE])
              .then(function(text) {
                state.refMaterial = text;
                fileNameEl.textContent = doc[google.picker.Document.NAME];
                selectedEl.classList.remove('hidden');
                btnPick.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg> Cambiar archivo';
                btnPick.disabled = false;
              })
              .catch(function(err) {
                btnPick.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg> Seleccionar archivo de Drive';
                btnPick.disabled = false;
                alert((window.__t ? window.__t('err.file') : 'No se pudo leer el archivo') + ': ' + (err.message || 'error desconocido'));
              });
          }
        })
        .build()
        .setVisible(true);
    }).catch(function() {
      alert(window.__t ? window.__t('err.picker') : 'Error al cargar Google Picker.');
    });
  });
})();

// ── GENERATION ────────────────────────────────────────────────────────────────
function getLoadingTexts() {
  var t = window.__t || function(k){ return k; };
  return [t('loading.1'), t('loading.2'), t('loading.3')];
}
function getLoadingTips() {
  var t = window.__t || function(k){ return k; };
  return [t('loading.tip.1'), t('loading.tip.2'), t('loading.tip.3')];
}

function startGeneration() {
  showStep('step-loading');

  var textEl = document.getElementById('loading-text');
  var tipEl  = document.getElementById('loading-tip-text');
  var ti = 0, tt = 0;
  var LOADING_TEXTS = getLoadingTexts();
  var LOADING_TIPS  = getLoadingTips();
  if (textEl) textEl.textContent = LOADING_TEXTS[0];
  if (tipEl)  tipEl.textContent  = LOADING_TIPS[0];

  var textTimer = setInterval(function() {
    tt = (tt + 1) % LOADING_TEXTS.length;
    textEl.textContent = LOADING_TEXTS[tt];
  }, 2500);

  var tipTimer = setInterval(function() {
    ti = (ti + 1) % LOADING_TIPS.length;
    tipEl.textContent = LOADING_TIPS[ti];
  }, 3500);

  fetch('/api/generate', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      mode:        state.mode,
      title:       state.title,
      subject:     state.subject,
      context:     state.context,
      intro:       state.intro,
      difficulty:  state.difficulty,
      text:        state.mode === 'format'
                     ? (state.pastedText || state.uploadedText)
                     : (state.refMaterial || state.uploadedText || ''),
      types:       state.types,
      googleToken: localStorage.getItem('gf_google_token')
    })
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    clearInterval(textTimer);
    clearInterval(tipTimer);
    if (data.error) throw new Error(data.error);
    showSuccess({
      title:   data.title,
      count:   data.count,
      formUrl: data.formUrl,
      editUrl: data.editUrl
    });
  })
  .catch(function(err) {
    clearInterval(textTimer);
    clearInterval(tipTimer);
    showStep('step-4');
    var msg = window.__t ? window.__t('err.generate') : 'Error al generar el formulario';
    alert(msg + ': ' + err.message);
  });
}

function showSuccess(data) {
  var t = window.__t || function(k){ return k; };
  document.getElementById('suc-name').textContent  = data.title;
  document.getElementById('suc-count').textContent = data.count + ' ' + t('suc.count.suffix');
  document.getElementById('suc-folder').textContent = state.folderName || t('folder.default');
  document.getElementById('btn-open-form').href  = data.formUrl || '#';
  document.getElementById('btn-open-drive').href = data.editUrl || '#';

  var checkSvg = document.querySelector('.success-check svg');
  if (checkSvg) checkSvg.classList.add('animate');

  showStep('step-success');

  document.dispatchEvent(new CustomEvent('gf:form-created', {
    detail: { title: data.title, formUrl: data.formUrl || '', editUrl: data.editUrl || '' }
  }));
}

// ── RESTART ───────────────────────────────────────────────────────────────────
document.getElementById('btn-restart').addEventListener('click', function() {
  state.mode = null;
  state.title = state.subject = state.context = state.intro = '';
  state.pastedText = state.uploadedText = state.solucionarioText = '';
  state.refMaterial = ''; state.keepAsIs = false; state.solucionario = false;
  state.difficulty = 'medio';
  state.types = {
    multiple_choice: { on: true,  count: 5 },
    true_false:      { on: true,  count: 5 },
    short_answer:    { on: false, count: 0 },
    checkboxes:      { on: false, count: 0 }
  };
  // Reset UI
  var modeGen = document.getElementById('mode-generate');
  var modeFmt = document.getElementById('mode-format');
  modeGen.classList.remove('selected'); modeFmt.classList.remove('selected');
  document.getElementById('btn1-next').disabled = true;
  var checkSvg = document.querySelector('.success-check svg');
  if (checkSvg) checkSvg.classList.remove('animate');
  showStep('step-1');
});

