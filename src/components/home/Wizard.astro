      btn.classList.add('active');
      state.difficulty = btn.getAttribute('data-val');
    });
  });

  // Reference tabs
  var tabPaste   = document.getElementById('ref-tab-paste');
  var tabDrive   = document.getElementById('ref-tab-drive');
  var panelPaste = document.getElementById('ref-panel-paste');
