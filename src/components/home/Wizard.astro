    tabPaste.classList.add('active'); tabDrive.classList.remove('active');
    panelPaste.classList.remove('hidden'); panelDrive.classList.add('hidden');
  });
  tabDrive.addEventListener('click', function() {
    tabDrive.classList.add('active'); tabPaste.classList.remove('active');
    panelDrive.classList.remove('hidden'); panelPaste.classList.add('hidden');
  });

  // Collapsible intro
  introHdr.addEventListener('click', function() {
    introHdr.classList.toggle('open');
    introBody.classList.toggle('open');
  });

  function validate() {
    btnNext.disabled = !(inpTitle.value.trim() && inpSubject.value.trim());
  }
  inpTitle.addEventListener('input', validate);
  inpSubject.addEventListener('input', validate);

  btnBack.addEventListener('click', function() { showStep('step-1'); });
  btnNext.addEventListener('click', function() {
    state.title   = inpTitle.value.trim();
    state.subject = inpSubject.value.trim();
    state.context = document.getElementById('inp-context').value.trim();
    state.intro   = document.getElementById('inp-intro').value.trim();
    // Only take the textarea value if the paste tab is active (Drive file sets state.refMaterial directly)
    if (tabPaste.classList.contains('active')) {
      state.refMaterial = document.getElementById('inp-ref-text').value.trim();
    }
