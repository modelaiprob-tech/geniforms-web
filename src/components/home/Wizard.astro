// ── SESSION RESTORE ───────────────────────────────────────────────────────────
// Guarda el step antes de ir al login
document.getElementById('modal-login-btn').addEventListener('click', function() {
  sessionStorage.setItem('gf_restore_step', currentStepId);
});

// ── INIT ──────────────────────────────────────────────────────────────────────
(function init() {
  var restore = sessionStorage.getItem('gf_restore_step');
  if (restore && isLoggedIn && STEP_ORDER.indexOf(restore) !== -1) {
    sessionStorage.removeItem('gf_restore_step');
    showStep(restore);
  } else {
    showStep('step-1');
  }
})();
</script>

<script>
  // Guarda el formulario generado en Firestore cuando el usuario está autenticado
  import { auth } from '../../lib/firebase';
  import { db } from '../../lib/firebase';
  import { collection, addDoc } from 'firebase/firestore';

  document.addEventListener('gf:form-created', async (e: Event) => {
    const user = auth.currentUser;
    if (!user) return;
    const { title, formUrl, editUrl } = (e as CustomEvent<{ title: string; formUrl: string; editUrl: string }>).detail;
    try {
      await addDoc(collection(db, 'forms'), {
        userId:    user.uid,
        title,
        formUrl,
        editUrl,
        createdAt: new Date().toISOString(),
      });
      document.dispatchEvent(new CustomEvent('gf:history-updated'));
    } catch (err) {
      console.error('Error al guardar historial de formulario:', err);
    }
  });
</script>
