---
interface Props {
  isLoggedIn: boolean;
}
const { isLoggedIn } = Astro.props;
const googleApiKey = import.meta.env.PUBLIC_GOOGLE_API_KEY ?? '';
---

<div class="wiz-wrap">
  <div class="wiz" id="wizard">

    <!-- ── PROGRESS BAR ── -->
    <div class="wiz-progress" id="wiz-progress">
      <div class="wiz-prog-track">
        <div class="wiz-prog-fill" id="wiz-prog-fill"></div>
      </div>
      <div class="wiz-prog-steps">
        <div class="wiz-prog-step active" data-step="1"><span>1</span></div>
        <div class="wiz-prog-step" data-step="2"><span>2</span></div>
        <div class="wiz-prog-step" data-step="3"><span>3</span></div>
        <div class="wiz-prog-step" data-step="4"><span>4</span></div>
      </div>
    </div>

    <!-- ══════════════════════════════════════════════════════ STEP 1 — Modo -->
    <div class="wiz-step active" id="step-1">
      <div class="wiz-body">
        <div class="section-title" data-i18n="s1.title">&#191;C&oacute;mo quieres crear tu cuestionario?</div>

        <div id="mode-generate" class="mode-card" tabindex="0" role="button" aria-pressed="false">
          <div class="mode-icon mode-icon--purple">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#5B2D9E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3v1m0 16v1M4.22 4.22l.7.7m12.16 12.16.7.7M3 12h1m16 0h1M4.22 19.78l.7-.7M18.36 5.64l.7-.7"/>
              <circle cx="12" cy="12" r="4"/>
            </svg>
          </div>
          <div>
            <div class="mode-title" data-i18n="mode.gen.title">Generar desde cero</div>
            <div class="mode-desc" data-i18n="mode.gen.desc">La IA dise&ntilde;a preguntas seg&uacute;n tu materia y objetivo pedag&oacute;gico</div>
          </div>
        </div>

        <div id="mode-format" class="mode-card" tabindex="0" role="button" aria-pressed="false">
          <div class="mode-icon mode-icon--cyan">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#00A8C8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
            </svg>
          </div>
          <div>
            <div class="mode-title" data-i18n="mode.fmt.title">Tengo el cuestionario escrito</div>
            <div class="mode-desc" data-i18n="mode.fmt.desc">Pega tu texto o sube un archivo para convertirlo en formulario</div>
          </div>
        </div>

        <div class="tip-card">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2a7 7 0 0 1 7 7c0 4-3 6-3 9H8c0-3-3-5-3-9a7 7 0 0 1 7-7z"/>
            <line x1="8" y1="22" x2="16" y2="22"/>
          </svg>
          <div>
            <div class="tip-card-title" data-i18n="tip.title">Consejo pedag&oacute;gico</div>
            <div class="tip-card-text" data-i18n="tip.text">Define bien el nivel y la materia para obtener preguntas m&aacute;s precisas y alineadas con tu curr&iacute;culo.</div>
          </div>
        </div>
      </div>
      <div class="wiz-footer">
        <button id="btn1-next" class="btn-primary" disabled data-i18n="btn.next">Siguiente</button>
      </div>
    </div>

    <!-- ══════════════════════════════════════════════════════ STEP 2A — Generar -->
    <div class="wiz-step" id="step-2a">
      <div class="wiz-body">
        <div class="section-title" data-i18n="s2a.title">Cu&eacute;ntanos sobre tu cuestionario.</div>
        <div class="card" style="display:flex;flex-direction:column;gap:14px">
          <div>
            <label class="field-label" for="inp-title" data-i18n="lbl.formtitle">T&iacute;tulo del formulario *</label>
            <input type="text" id="inp-title" placeholder="Ej: Examen Tema 3 &mdash; Fotos&iacute;ntesis">
          </div>
          <div>
            <label class="field-label" for="inp-subject" data-i18n="lbl.subject">Materia *</label>
            <input type="text" id="inp-subject" placeholder="Ej: Biolog&iacute;a, Historia, Matem&aacute;ticas...">
          </div>
          <div>
            <label class="field-label" for="inp-context" data-i18n="lbl.context">Contexto adicional</label>
            <textarea id="inp-context" rows="3" placeholder="Objetivo pedag&oacute;gico, nivel del curso, enfoque espec&iacute;fico..."></textarea>
          </div>
          <div>
            <label class="field-label" data-i18n="lbl.refmat">Material de referencia</label>
            <div class="ref-tabs">
              <button class="ref-tab active" id="ref-tab-paste" type="button" data-i18n="tab.paste">Pegar texto</button>
              <button class="ref-tab" id="ref-tab-drive" type="button">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:-1px;margin-right:4px"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                <span data-i18n="tab.drive">Desde Drive</span>
              </button>
            </div>
            <div id="ref-panel-paste">
              <textarea id="inp-ref-text" rows="4" placeholder="Apuntes, temario, fragmento del libro..."></textarea>
            </div>
            <div id="ref-panel-drive" class="hidden">
              <button id="btn-pick-ref-file" class="btn-pick-drive" type="button">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                <span data-i18n="btn.pickfile">Seleccionar archivo de Drive</span>
              </button>
              <div id="ref-file-selected" class="hidden" style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--accent);padding-top:6px">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                <span id="ref-file-name"></span>
              </div>
            </div>
          </div>
          <div>
            <div class="collapsible-hdr" id="intro-hdr">
              <span class="field-label" style="margin:0" data-i18n="lbl.intro">Introducci&oacute;n (opcional)</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </div>
            <div class="collapsible-body" id="intro-body">
              <div class="inner">
                <textarea id="inp-intro" rows="3" placeholder="Texto introductorio para el formulario..."></textarea>
              </div>
            </div>
          </div>
          <div>
            <label class="field-label" data-i18n="lbl.diff">Dificultad</label>
            <div class="diff-selector">
              <button class="diff-opt" data-val="facil" data-i18n="diff.easy">F&aacute;cil</button>
              <button class="diff-opt active" data-val="medio" data-i18n="diff.med">Medio</button>
              <button class="diff-opt" data-val="dificil" data-i18n="diff.hard">Dif&iacute;cil</button>
            </div>
          </div>
        </div>
      </div>
      <div class="wiz-footer">
        <button id="btn2a-back" class="btn-secondary" data-i18n="btn.back">Atr&aacute;s</button>
        <button id="btn2a-next" class="btn-primary" disabled data-i18n="btn.next">Siguiente</button>
      </div>
    </div>

    <!-- ══════════════════════════════════════════════════════ STEP 2B — Formato -->
    <div class="wiz-step" id="step-2b">
      <div class="wiz-body">
        <div class="section-title" data-i18n="s2b.title">Pega aqu&iacute; tu cuestionario.</div>
        <div class="card" style="display:flex;flex-direction:column;gap:14px">
          <div>
            <label class="field-label" for="inp-title-b">T&iacute;tulo del formulario *</label>
            <input type="text" id="inp-title-b" placeholder="Ej: Repaso Unidad 2">
          </div>
          <div>
            <label class="field-label" for="inp-paste" data-i18n="lbl.quiztext">Texto del cuestionario</label>
            <textarea id="inp-paste" rows="8" placeholder="Pega aqu&iacute; las preguntas...&#10;&#10;1. Cu&aacute;l es la capital de Francia?&#10;A) Berl&iacute;n  B) Par&iacute;s  C) Madrid  D) Roma&#10;Respuesta: B"></textarea>
          </div>
          <div>
            <label class="field-label">O sube un archivo</label>
            <div class="upload-zone" id="upload-zone" tabindex="0" role="button" aria-label="Subir archivo">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="16 16 12 12 8 16"/>
                <line x1="12" y1="12" x2="12" y2="21"/>
                <path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/>
              </svg>
              <div class="upload-zone-title" data-i18n="upload.title">Arrastra o haz click para subir</div>
              <div class="upload-zone-sub" data-i18n="upload.sub">.txt &middot; .pdf &middot; .docx &mdash; max 10 MB</div>
              <div class="upload-zone-file" id="upload-filename"></div>
              <input type="file" id="file-input" accept=".txt,.pdf,.docx" style="display:none">
            </div>
            <div id="upload-warn" class="warn-card hidden" style="margin-top:8px">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
              </svg>
              <span data-i18n="upload.warn">Solo archivos .txt en esta versi&oacute;n. Para .pdf y .docx, copia el texto y p&eacute;galo arriba.</span>
            </div>
          </div>
          <div class="tip-card amber">
            <span style="font-size:16px;line-height:1;flex-shrink:0;margin-top:1px">&#128161;</span>
            <div class="tip-card-text" data-i18n="tip.sol.text">Si tienes el solucionario, p&eacute;galo abajo. La IA asignar&aacute; las respuestas correctas con mayor precisi&oacute;n.</div>
          </div>
          <div>
            <div class="collapsible-hdr" id="sol-hdr">
              <div style="display:flex;align-items:center;gap:8px">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0">
                  <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/>
                </svg>
                <span class="field-label" style="margin:0" data-i18n="lbl.sol">&iquest;Tienes el solucionario? (opcional)</span>
              </div>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </div>
            <div class="collapsible-body" id="sol-body">
              <div class="inner">
                <textarea id="inp-solucionario" rows="5" placeholder="Pega aqu&iacute; las respuestas correctas o el solucionario. Esto ayuda a la IA a identificar las opciones correctas con precisi&oacute;n."></textarea>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="wiz-footer">
        <button id="btn2b-back" class="btn-secondary" data-i18n="btn.back">Atr&aacute;s</button>
        <button id="btn2b-next" class="btn-primary" disabled data-i18n="btn.next">Siguiente</button>
      </div>
    </div>

    <!-- ══════════════════════════════════════════════════════ STEP 3 — Tipos -->
    <div class="wiz-step" id="step-3">
      <div class="wiz-body">
        <div class="section-title" data-i18n="s3.title">Configura tus preguntas.</div>
        <div class="card">
          <div class="type-row">
            <div class="type-checkbox checked" id="chk-mc"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1.5 6 4.5 9 10.5 3"/></svg></div>
            <div class="type-name" data-i18n="type.mc">Opci&oacute;n m&uacute;ltiple (ABCD)</div>
            <div class="type-count active" id="tc-mc"><input type="number" id="inp-count-mc" value="5" min="0" max="50"></div>
          </div>
          <div class="type-row">
            <div class="type-checkbox checked" id="chk-vf"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1.5 6 4.5 9 10.5 3"/></svg></div>
            <div class="type-name" data-i18n="type.vf">Verdadero / Falso</div>
            <div class="type-count active" id="tc-vf"><input type="number" id="inp-count-vf" value="5" min="0" max="50"></div>
          </div>
          <div class="type-row">
            <div class="type-checkbox" id="chk-short"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1.5 6 4.5 9 10.5 3"/></svg></div>
            <div class="type-name" data-i18n="type.short">Respuesta corta</div>
            <div class="type-count" id="tc-short"><input type="number" id="inp-count-short" value="0" min="0" max="50"></div>
          </div>
          <div class="type-row">
            <div class="type-checkbox" id="chk-cb"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1.5 6 4.5 9 10.5 3"/></svg></div>
            <div class="type-name" data-i18n="type.cb">Casillas (multi-respuesta)</div>
            <div class="type-count" id="tc-cb"><input type="number" id="inp-count-cb" value="0" min="0" max="50"></div>
          </div>
          <div class="type-total">Total: <strong id="type-total-num">10</strong> <span data-i18n="total.suffix">preguntas</span></div>
        </div>

        <div id="short-warn" class="warn-card hidden">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
            <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
          </svg>
          <span data-i18n="warn.short">Las preguntas de respuesta corta no pueden corregirse autom&aacute;ticamente en Google Forms.</span>
        </div>

        <div id="keepasis-card" class="hidden" style="background:rgba(0,212,255,0.06);border:1px solid rgba(0,212,255,0.22);border-radius:12px;padding:12px 14px;display:flex;gap:10px;align-items:flex-start">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#007A99" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:1px">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          <div style="font-size:12px;color:#007A99;line-height:1.5">
            <strong style="display:block;margin-bottom:2px" data-i18n="keepasis.title">Tienes texto pegado</strong>
            <span data-i18n="keepasis.text">Puedes configurar los tipos arriba, o dejar que la IA detecte los tipos y respuestas directamente de tu texto.</span>
          </div>
        </div>
      </div>
      <div class="wiz-footer wiz-footer--col">
        <div style="display:flex;gap:10px;width:100%">
          <button id="btn3-back" class="btn-secondary" style="flex:1" data-i18n="btn.back">Atr&aacute;s</button>
          <button id="btn3-next" class="btn-primary" style="flex:2" disabled data-i18n="btn.next">Siguiente</button>
        </div>
        <button id="btn3-keepasis" class="btn-secondary hidden" style="width:100%" data-i18n="btn.keepasis">Conservar tal como est&aacute;</button>
      </div>
    </div>

    <!-- ══════════════════════════════════════════════════════ STEP 4 — Drive -->
    <div class="wiz-step" id="step-4">
      <div class="wiz-body">
        <div class="section-title" data-i18n="s4.title">&iquest;D&oacute;nde guardamos el formulario?</div>

        <button id="btn-pick-folder" class="btn-pick-drive" type="button">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
          <span data-i18n="btn.pickfolder">Seleccionar carpeta en Drive</span>
        </button>
        <div class="folder-selected">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
          <span id="drive-folder-name" data-i18n="folder.default">Mi Drive (ra&iacute;z)</span>
        </div>

        <!-- Solucionario toggle -->
        <div class="toggle-row">
          <div>
            <div class="toggle-label" data-i18n="toggle.sol.label">Generar solucionario</div>
            <div class="toggle-sub" data-i18n="toggle.sol.sub">Descarga con explicaciones detalladas</div>
          </div>
          <button id="sol-toggle" class="toggle-switch" role="switch" aria-checked="false"></button>
        </div>
      </div>
      <div class="wiz-footer">
        <button id="btn4-back" class="btn-secondary" data-i18n="btn.back">Atr&aacute;s</button>
        <button id="btn4-next" class="btn-primary" data-i18n="btn.create">Crear formulario</button>
      </div>
    </div>

    <!-- ══════════════════════════════════════════════════════ LOADING -->
    <div class="wiz-step" id="step-loading">
      <div class="wiz-body wiz-body--center">
        <div class="loading-spinner">
          <svg viewBox="0 0 50 50">
            <circle cx="25" cy="25" r="20" fill="none" stroke="#E5E7EB" stroke-width="4"/>
            <circle cx="25" cy="25" r="20" fill="none" stroke="url(#spin-grad)" stroke-width="4"
              stroke-linecap="round" stroke-dasharray="80" stroke-dashoffset="60"/>
            <defs>
              <linearGradient id="spin-grad" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#5B2D9E"/>
                <stop offset="100%" stop-color="#C848FF"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
        <div class="loading-text" id="loading-text">Generando tu cuestionario...</div>
        <div class="tip-card loading-tip" id="loading-tip-card">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2a7 7 0 0 1 7 7c0 4-3 6-3 9H8c0-3-3-5-3-9a7 7 0 0 1 7-7z"/>
            <line x1="8" y1="22" x2="16" y2="22"/>
          </svg>
          <div class="tip-card-text" id="loading-tip-text">Cuanto m&aacute;s espec&iacute;fico sea el tema, mejor ser&aacute; el resultado.</div>
        </div>
      </div>
    </div>

    <!-- ══════════════════════════════════════════════════════ SUCCESS -->
    <div class="wiz-step" id="step-success">
      <div class="wiz-body">
        <div class="success-check">
          <svg viewBox="0 0 36 36" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 18 14 26 30 10"/>
          </svg>
        </div>
        <div class="success-title" data-i18n="suc.title">Formulario creado</div>

        <div class="success-summary">
          <div class="summary-row">
            <span class="summary-key" data-i18n="suc.name">Nombre</span>
            <span class="summary-val" id="suc-name">&mdash;</span>
          </div>
          <div class="summary-row">
            <span class="summary-key">Preguntas</span>
            <span class="summary-val" id="suc-count">&mdash;</span>
          </div>
          <div class="summary-row">
            <span class="summary-key" data-i18n="suc.folder.key">Carpeta Drive</span>
            <span class="summary-val" id="suc-folder">Mi Drive</span>
          </div>
        </div>

        <div style="display:flex;flex-direction:column;gap:8px">
          <a id="btn-open-form" href="#" target="_blank" rel="noopener" class="btn-primary" style="text-align:center;text-decoration:none" data-i18n="btn.openform">Abrir formulario</a>
          <a id="btn-open-drive" href="#" target="_blank" rel="noopener" class="btn-secondary" style="text-align:center;text-decoration:none" data-i18n="btn.editform">Editar formulario</a>
          <button id="btn-restart" class="btn-text" data-i18n="btn.restart">Crear otro formulario</button>
        </div>
      </div>
    </div>

  </div><!-- /wiz -->
</div><!-- /wiz-wrap -->

<!-- Login modal ─────────────────────────────────────────────────────────────
     PLACEHOLDER: se muestra cuando el usuario intenta crear sin estar logueado.
────────────────────────────────────────────────────────────────────────────── -->
<div id="login-modal" class="modal-backdrop hidden" role="dialog" aria-modal="true" aria-labelledby="modal-title">
  <div class="modal-card">
    <button id="modal-close" class="modal-close" aria-label="Cerrar">&times;</button>
    <div style="width:64px;height:64px;border-radius:16px;background:#EDE8FA;display:flex;align-items:center;justify-content:center;margin:0 auto">
