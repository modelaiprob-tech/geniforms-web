<script define:vars={{ isLoggedIn, googleApiKey }}>
// ── STATE ──────────────────────────────────────────────────────────────────────
var state = {
  mode:             null,     // 'generate' | 'format'
  title:            '',
  subject:          '',
  context:          '',
  intro:            '',
  difficulty:       'medio',
  refMaterial:      '',
  pastedText:       '',
  uploadedText:     '',
  solucionarioText: '',
  solucionario:     false,
  folderId:         'root',
  folderName:       'Mi Drive (raiz)',
  types: {
    multiple_choice: { on: true,  count: 5 },
    true_false:      { on: true,  count: 5 },
    short_answer:    { on: false, count: 0 },
    checkboxes:      { on: false, count: 0 }
  },
  keepAsIs: false,
  isLoggedIn: isLoggedIn
};

// ── STEPS / PROGRESS ──────────────────────────────────────────────────────────
var STEP_ORDER = ['step-1','step-2a','step-2b','step-3','step-4','step-loading','step-success'];
var STEP_NUM   = { 'step-1': 1, 'step-2a': 2, 'step-2b': 2, 'step-3': 3, 'step-4': 4 };
var currentStepId = 'step-1';

function showStep(id) {
  currentStepId = id;
  STEP_ORDER.forEach(function(s) {
    var el = document.getElementById(s);
    if (el) el.classList.toggle('active', s === id);
  });
  updateProgress(id);
}

function updateProgress(id) {
  var progWrap = document.getElementById('wiz-progress');
  var fill     = document.getElementById('wiz-prog-fill');
  var isLoading  = id === 'step-loading';
  var isSuccess  = id === 'step-success';

  progWrap.style.display = (isLoading || isSuccess) ? 'none' : '';

  var current = STEP_NUM[id] || 0;
  var dots = document.querySelectorAll('.wiz-prog-step');
  dots.forEach(function(dot) {
    var n = parseInt(dot.getAttribute('data-step'), 10);
    dot.classList.toggle('active', n === current);
    dot.classList.toggle('done', n < current);
  });

  var pct = current > 1 ? ((current - 1) / 3) * 100 : 0;
  if (fill) fill.style.width = pct + '%';
}

// ── STEP 1 ────────────────────────────────────────────────────────────────────
(function initStep1() {
  var modeGen = document.getElementById('mode-generate');
  var modeFmt = document.getElementById('mode-format');
  var btnNext = document.getElementById('btn1-next');

  function selectMode(m) {
    state.mode = m;
    modeGen.classList.toggle('selected', m === 'generate');
    modeFmt.classList.toggle('selected', m === 'format');
    modeGen.setAttribute('aria-pressed', m === 'generate' ? 'true' : 'false');
    modeFmt.setAttribute('aria-pressed', m === 'format'   ? 'true' : 'false');
    btnNext.disabled = false;
  }

  modeGen.addEventListener('click', function() { selectMode('generate'); });
  modeFmt.addEventListener('click', function() { selectMode('format'); });
  modeGen.addEventListener('keydown', function(e) { if (e.key === 'Enter' || e.key === ' ') selectMode('generate'); });
  modeFmt.addEventListener('keydown', function(e) { if (e.key === 'Enter' || e.key === ' ') selectMode('format'); });

  btnNext.addEventListener('click', function() {
    if (!state.mode) return;
    showStep(state.mode === 'generate' ? 'step-2a' : 'step-2b');
  });
})();

// ── STEP 2A ───────────────────────────────────────────────────────────────────
(function initStep2a() {
  var inpTitle   = document.getElementById('inp-title');
  var inpSubject = document.getElementById('inp-subject');
  var btnBack    = document.getElementById('btn2a-back');
  var btnNext    = document.getElementById('btn2a-next');
