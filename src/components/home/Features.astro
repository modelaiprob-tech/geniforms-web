---
const features = [
  {
    icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="2" y="2" width="14" height="14" rx="3" stroke="#5B2D9E" stroke-width="1.5"/><path d="M5.5 9l2 2 5-4" stroke="#5B2D9E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    text: 'Se crea directamente en tu Google Drive',
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="7" stroke="#5B2D9E" stroke-width="1.5"/><path d="M9 5v4l2.5 2.5" stroke="#5B2D9E" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    text: 'Listo en segundos con Gemini 2.5 Flash',
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 2L2 6v6l7 4 7-4V6L9 2z" stroke="#5B2D9E" stroke-width="1.5" stroke-linejoin="round"/><path d="M2 6l7 4 7-4" stroke="#5B2D9E" stroke-width="1.5"/><path d="M9 10v6" stroke="#5B2D9E" stroke-width="1.5"/></svg>`,
    text: 'Compatible con Google Forms y Google Docs',
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 2a7 7 0 100 14A7 7 0 009 2z" stroke="#5B2D9E" stroke-width="1.5"/><path d="M9 6v3.5l2 2" stroke="#5B2D9E" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    text: '100% gratuito de momento',
  },
];
---

<section class="features" aria-label="Caracter&iacute;sticas">
  <ul class="features-list">
    {features.map(f => (
      <li class="feature-item">
        <span class="feature-icon" set:html={f.icon} />
        <span class="feature-text">{f.text}</span>
      </li>
    ))}
  </ul>
</section>

<style>
  .features {
    padding: 0 24px 64px;
    display: flex;
    justify-content: center;
  }

  .features-list {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 8px 32px;
    flex-wrap: wrap;
    justify-content: center;
    max-width: 660px;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 7px;
  }

  .feature-icon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .feature-text {
    font-size: 13px;
    color: var(--text-2);
  }
</style>
