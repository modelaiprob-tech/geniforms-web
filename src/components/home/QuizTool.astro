---
// La tool principal de la home — textarea + opciones + botón generar.
// La lógica de generación (Gemini API + Google Forms) irá en src/pages/api/generate.ts
// La lógica de auth check es client-side: si no hay sesión → modal de login.

interface Props {
  isLoggedIn: boolean;
}

const { isLoggedIn } = Astro.props;
---

<section class="tool-section">
  <div class="tool-card">
    <!-- Textarea -->
    <div class="tool-field">
      <label for="quiz-input" class="tool-label">Tema o texto</label>
      <textarea
        id="quiz-input"
        class="tool-textarea"
        rows="6"
        placeholder="Escribe un tema (ej: 'La Segunda Guerra Mundial') o pega directamente el texto del que quieres generar preguntas..."
        aria-label="Tema o texto para generar cuestionario"
      ></textarea>
    </div>

    <!-- Opciones -->
    <div class="tool-options">
      <!-- Tipo de preguntas -->
      <div class="option-group">
        <span class="option-label">Tipo</span>
        <div class="pill-group" role="group" aria-label="Tipo de preguntas">
          <button class="pill active" data-type="mixed">Mixto</button>
          <button class="pill" data-type="abcd">Opci&oacute;n m&uacute;ltiple</button>
          <button class="pill" data-type="vf">Verdadero / Falso</button>
        </div>
      </div>

      <!-- Número de preguntas -->
      <div class="option-group option-group--num">
        <label for="quiz-count" class="option-label">Preguntas</label>
        <div class="num-control">
          <button class="num-btn" id="num-dec" aria-label="Menos preguntas">&#8722;</button>
          <input
            type="number"
            id="quiz-count"
            class="num-input"
            value="10"
            min="3"
            max="30"
            aria-label="Número de preguntas"
          />
          <button class="num-btn" id="num-inc" aria-label="M&#225;s preguntas">&#43;</button>
        </div>
      </div>
    </div>

    <!-- Botón generar -->
    <button
      id="btn-generate"
      class="btn-generate"
      data-logged-in={isLoggedIn ? 'true' : 'false'}
      aria-label="Generar cuestionario"
    >
      <span id="btn-generate-text">Generar cuestionario</span>
      <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <!-- Spinner (oculto por defecto) -->
      <svg class="btn-spinner hidden" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <circle cx="8" cy="8" r="6" stroke="rgba(255,255,255,0.3)" stroke-width="2"/>
        <path d="M8 2a6 6 0 016 6" stroke="#fff" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>

    <!-- Error inline -->
    <p id="tool-error" class="tool-error hidden" role="alert"></p>
  </div>
</section>

<!-- Modal login ──────────────────────────────────────────────────────────────
     PLACEHOLDER: se muestra cuando el usuario pulsa "Generar" sin estar logueado.
     El href del botón apunta a /auth/login que aún no está implementado.
────────────────────────────────────────────────────────────────────────────── -->
<div id="login-modal" class="modal-backdrop hidden" role="dialog" aria-modal="true" aria-labelledby="modal-title">
  <div class="modal-card">
    <button id="modal-close" class="modal-close" aria-label="Cerrar">&times;</button>
    <div class="modal-icon">
      <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
        <rect width="40" height="40" rx="12" fill="#EDE8FA"/>
        <path d="M20 10c-5.523 0-10 4.477-10 10s4.477 10 10 10 10-4.477 10-10S25.523 10 20 10z" stroke="#5B2D9E" stroke-width="1.5"/>
        <path d="M23 16.5a3 3 0 11-6 0 3 3 0 016 0zM13.5 29a6.5 6.5 0 0113 0" stroke="#5B2D9E" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </div>
    <h2 id="modal-title" class="modal-title">Inicia sesi&oacute;n para continuar</h2>
    <p class="modal-text">Conecta tu cuenta de Google para generar cuestionarios y guardarlos en tu Drive.</p>
    <!-- PLACEHOLDER: href="/auth/login" → endpoint de Supabase OAuth (ver src/lib/auth.ts) -->
    <a href="/auth/login" class="btn-google">
      <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
        <path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.874 2.684-6.615z"/>
        <path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.184l-2.908-2.258c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 009 18z"/>
        <path fill="#FBBC05" d="M3.964 10.707A5.41 5.41 0 013.682 9c0-.593.102-1.17.282-1.707V4.961H.957A8.996 8.996 0 000 9c0 1.452.348 2.827.957 4.039l3.007-2.332z"/>
        <path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 00.957 4.961L3.964 6.293C4.672 4.166 6.656 3.58 9 3.58z"/>
      </svg>
      Continuar con Google
    </a>
  </div>
</div>

<style>
  /* ── Tool section ── */
  .tool-section {
    padding: 8px 24px 48px;
    display: flex;
    justify-content: center;
  }

  .tool-card {
    width: 100%;
    max-width: 660px;
    background: var(--card);
    border-radius: var(--radius-lg);
    box-shadow: 0 2px 8px rgba(91,45,158,0.07);
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Textarea */
  .tool-field { display: flex; flex-direction: column; gap: 6px; }

  .tool-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-2);
  }

  .tool-textarea {
    width: 100%;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-md);
    padding: 10px 12px;
    font-family: var(--font);
    font-size: 13px;
    color: var(--text);
    background: var(--card);
    outline: none;
    resize: none;
    line-height: 1.5;
    transition: border-color 0.15s;
    -webkit-appearance: none;
    appearance: none;
  }

  .tool-textarea:focus { border-color: var(--accent); }
  .tool-textarea::placeholder { color: #C4C9D4; }

  /* Options row */
  .tool-options {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .option-group {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .option-group--num { margin-left: auto; }

  .option-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-2);
    white-space: nowrap;
  }

  /* Pill group */
  .pill-group { display: flex; gap: 4px; }

  .pill {
    padding: 9px 12px;
    border: 1.5px solid #E0E0E0;
    border-radius: 16px;
    background: var(--card);
    font-family: var(--font);
    font-size: 13px;
    font-weight: 500;
    color: var(--text-2);
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
    white-space: nowrap;
  }

  .pill.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
    font-weight: 700;
  }

  .pill:hover:not(.active) { border-color: var(--accent); color: var(--accent); }

  /* Number control */
  .num-control {
    display: flex;
    align-items: center;
    gap: 0;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .num-btn {
    width: 32px;
    height: 36px;
    background: var(--card);
    border: none;
    font-size: 16px;
    color: var(--text-2);
    cursor: pointer;
    transition: background 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .num-btn:hover { background: #F0EBF8; color: var(--accent); }

  .num-input {
    width: 48px;
    height: 36px;
    border: none;
    border-left: 1px solid var(--border);
    border-right: 1px solid var(--border);
    border-radius: 0;
    text-align: center;
    font-family: var(--font);
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    background: var(--card);
    outline: none;
    -moz-appearance: textfield;
    appearance: textfield;
  }

  .num-input::-webkit-inner-spin-button,
  .num-input::-webkit-outer-spin-button { -webkit-appearance: none; }

  /* Generate button — igual que .btn-primary de la extensión */
  .btn-generate {
    width: 100%;
    padding: 12px 20px;
    background: linear-gradient(135deg, var(--accent) 0%, var(--magenta) 100%);
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    font-family: var(--font);
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: opacity 0.15s, transform 0.1s;
  }

  .btn-generate:hover { opacity: 0.92; }
  .btn-generate:active { transform: scale(0.98); }
  .btn-generate:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

  .btn-spinner { animation: spin 0.8s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Error */
  .tool-error {
    font-size: 13px;
    color: #DC2626;
    text-align: center;
    margin-top: -4px;
  }

  /* ── Login modal ── */
  .modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(26,26,46,0.5);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 200;
    padding: 24px;
  }

  .modal-card {
    background: var(--card);
    border-radius: var(--radius-lg);
    padding: 32px;
    width: 100%;
    max-width: 380px;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    box-shadow: var(--shadow-md);
  }

  .modal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    font-size: 20px;
    color: var(--text-2);
    cursor: pointer;
    line-height: 1;
    padding: 4px;
  }

  .modal-close:hover { color: var(--text); }

  .modal-icon { margin-bottom: 4px; }

  .modal-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
    text-align: center;
  }

  .modal-text {
    font-size: 14px;
    color: var(--text-2);
    text-align: center;
    line-height: 1.5;
    margin-bottom: 4px;
  }

  .btn-google {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 12px;
    background: var(--card);
    border: 1.5px solid var(--border);
    border-radius: var(--radius-md);
    font-family: var(--font);
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    cursor: pointer;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .btn-google:hover {
    border-color: var(--accent);
    box-shadow: 0 2px 8px rgba(91,45,158,0.12);
  }

  /* Utilities */
  .hidden { display: none !important; }
</style>

<script>
  // ── Pill selector (tipo de preguntas) ────────────────────────────────────
  document.querySelectorAll('.pill').forEach(function(pill) {
    pill.addEventListener('click', function() {
      document.querySelectorAll('.pill').forEach(function(p) { p.classList.remove('active'); });
      pill.classList.add('active');
    });
  });

  // ── Número de preguntas ─────────────────────────────────────────────────
  var input = document.getElementById('quiz-count');
  document.getElementById('num-dec').addEventListener('click', function() {
    var v = parseInt(input.value, 10);
    if (v > parseInt(input.min, 10)) input.value = v - 1;
  });
  document.getElementById('num-inc').addEventListener('click', function() {
    var v = parseInt(input.value, 10);
    if (v < parseInt(input.max, 10)) input.value = v + 1;
  });

  // ── Botón generar ────────────────────────────────────────────────────────
  var btnGenerate  = document.getElementById('btn-generate');
  var btnText      = document.getElementById('btn-generate-text');
  var btnArrow     = btnGenerate.querySelector('.btn-arrow');
  var btnSpinner   = btnGenerate.querySelector('.btn-spinner');
  var toolError    = document.getElementById('tool-error');
  var loginModal   = document.getElementById('login-modal');

  btnGenerate.addEventListener('click', function() {
    toolError.classList.add('hidden');
    var text = document.getElementById('quiz-input').value.trim();

    if (!text) {
      toolError.textContent = 'Escribe un tema o pega un texto antes de continuar.';
      toolError.classList.remove('hidden');
      return;
    }

    var isLoggedIn = btnGenerate.dataset.loggedIn === 'true';

    if (!isLoggedIn) {
      // PLACEHOLDER: mostrar modal de login hasta que Supabase esté activo
      loginModal.classList.remove('hidden');
      return;
    }

    // ── PLACEHOLDER: lógica de generación ────────────────────────────────
    // Cuando Supabase + Gemini estén listos, reemplazar con:
    //
    // setLoading(true);
    // const type = document.querySelector('.pill.active').dataset.type;
    // const count = parseInt(document.getElementById('quiz-count').value, 10);
    // const response = await fetch('/api/generate', {
    //   method: 'POST',
    //   headers: { 'Content-Type': 'application/json' },
    //   body: JSON.stringify({ text, type, count }),
    // });
    // const data = await response.json();
    // if (data.error) { showError(data.error); setLoading(false); return; }
    // window.location.href = '/result?formId=' + data.formId;
    // ─────────────────────────────────────────────────────────────────────

    toolError.textContent = 'La generaci\u00f3n de cuestionarios estara disponible pronto.';
    toolError.classList.remove('hidden');
  });

  // ── Cerrar modal ─────────────────────────────────────────────────────────
  document.getElementById('modal-close').addEventListener('click', function() {
    loginModal.classList.add('hidden');
  });

  loginModal.addEventListener('click', function(e) {
    if (e.target === loginModal) loginModal.classList.add('hidden');
  });
</script>
