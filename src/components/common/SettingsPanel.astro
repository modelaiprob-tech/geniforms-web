---
// Panel lateral de ajustes: historial de formularios + reporte de incidencias
---

<!-- Backdrop -->
<div id="panel-backdrop" class="panel-backdrop"></div>

<!-- Panel -->
<aside id="settings-panel" class="settings-panel" aria-label="Panel de ajustes">
  <div class="panel-header">
    <h2 class="panel-title" id="panel-title" data-i18n="panel.forms">Mis formularios</h2>
    <button class="panel-close" id="panel-close" aria-label="Cerrar panel">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Vista: Mis formularios -->
  <div id="view-forms" class="panel-view">
    <div id="history-list" class="history-list">
      <p class="panel-loading">Cargando...</p>
    </div>
  </div>

  <!-- Vista: Reportar problema -->
  <div id="view-report" class="panel-view" style="display:none">
    <p class="report-desc" data-i18n="panel.report.desc">Describe el problema que encontraste y te responderemos por email.</p>
    <textarea
      id="inc-desc"
      class="panel-textarea"
      rows="5"
      data-i18n-ph="panel.report.ph"
      placeholder="Describe el problema..."
      maxlength="2000"
    ></textarea>
    <div class="report-footer">
      <span id="inc-chars" class="inc-chars">0 / 2000</span>
      <button id="inc-submit" class="panel-btn" data-i18n="panel.report.btn">Enviar reporte</button>
    </div>
    <p id="inc-msg" class="inc-msg" style="display:none"></p>
  </div>
</aside>

<style>
  .panel-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(26,26,46,0.35);
    backdrop-filter: blur(2px);
    z-index: 300;
  }
  .panel-backdrop.open { display: block; }

  .settings-panel {
    position: fixed;
    top: 0;
    right: 0;
    height: 100vh;
    width: 380px;
    max-width: 100vw;
    background: var(--card);
    border-left: 1px solid var(--border);
    box-shadow: -8px 0 32px rgba(0,0,0,0.10);
    z-index: 301;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .settings-panel.open { transform: translateX(0); }

  /* Header */
  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 20px 16px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }
  .panel-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
  }
  .panel-close {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: none;
    background: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-2);
    transition: background 0.12s, color 0.12s;
  }
  .panel-close:hover { background: rgba(91,45,158,0.07); color: var(--text); }

  /* Views */
  .panel-view {
    flex: 1;
    overflow-y: auto;
    padding: 16px 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  /* History */
  .history-spinner {
    display: flex;
    justify-content: center;
    padding: 32px 0;
  }
  .spinner-svg {
    width: 40px;
    height: 40px;
    animation: spin 0.9s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .panel-empty { font-size: 13px; color: var(--text-2); padding: 8px 0; }

  .history-list { display: flex; flex-direction: column; gap: 8px; }

  .history-card {
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 11px 13px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    transition: border-color 0.12s;
  }
  .history-card:hover { border-color: rgba(91,45,158,0.3); }

  .history-card-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 200px;
  }
  .history-card-date { font-size: 11px; color: var(--text-2); margin-top: 2px; }

  .history-card-actions { display: flex; gap: 6px; flex-shrink: 0; }

  .hbtn {
    padding: 5px 11px;
    border-radius: var(--radius-sm);
    font-size: 11px;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.12s;
    white-space: nowrap;
  }
  .hbtn:hover { opacity: 0.8; }
  .hbtn--primary   { background: var(--accent); color: #fff; }
  .hbtn--secondary { border: 1.5px solid var(--accent); color: var(--accent); }

  /* Report */
  .report-desc { font-size: 13px; color: var(--text-2); line-height: 1.5; }

  .panel-textarea {
    width: 100%;
    box-sizing: border-box;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-md);
    padding: 10px 12px;
    font-family: var(--font);
    font-size: 13px;
    color: var(--text);
    background: var(--bg);
    resize: none;
    outline: none;
    transition: border-color 0.15s;
    line-height: 1.5;
  }
  .panel-textarea:focus { border-color: var(--accent); }
  .panel-textarea::placeholder { color: #C4C9D4; }

  .report-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .inc-chars { font-size: 11px; color: var(--text-2); }

  .panel-btn {
    padding: 9px 18px;
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    font-family: var(--font);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .panel-btn:hover    { opacity: 0.88; }
  .panel-btn:disabled { opacity: 0.45; cursor: not-allowed; }

  .inc-msg           { font-size: 12px; line-height: 1.4; }
  .inc-msg--ok       { color: #16A34A; }
  .inc-msg--error    { color: #DC2626; }
</style>

<script>
  import { auth } from '../../lib/firebase';
  import { db } from '../../lib/firebase';
  import { collection, query, where, getDocs, addDoc } from 'firebase/firestore';

  const panel    = document.getElementById('settings-panel')!;
  const backdrop = document.getElementById('panel-backdrop')!;
  const closeBtn = document.getElementById('panel-close')!;
  const title    = document.getElementById('panel-title')!;
  const viewForms  = document.getElementById('view-forms')!;
  const viewReport = document.getElementById('view-report')!;

  const t = (k: string) => (window as any).__t?.(k) ?? k;

  // ── Open / close ────────────────────────────────────────────────────────────
  function openPanel(view: 'forms' | 'report') {
    panel.classList.add('open');
    backdrop.classList.add('open');
    document.body.style.overflow = 'hidden';

    if (view === 'forms') {
      title.textContent = t('panel.forms');
      viewForms.style.display  = 'flex';
      viewReport.style.display = 'none';
      const user = auth.currentUser;
      if (user) loadHistory(user.uid);
    } else {
      title.textContent = t('panel.report');
      viewForms.style.display  = 'none';
      viewReport.style.display = 'flex';
    }
  }

  function closePanel() {
    panel.classList.remove('open');
    backdrop.classList.remove('open');
    document.body.style.overflow = '';
  }

  closeBtn.addEventListener('click', closePanel);
  backdrop.addEventListener('click', closePanel);

  document.addEventListener('gf:open-panel', (e: Event) => {
    const { view } = (e as CustomEvent<{ view: 'forms' | 'report' }>).detail;
    openPanel(view);
  });

  document.addEventListener('gf:history-updated', () => {
    const user = auth.currentUser;
    if (user && panel.classList.contains('open') && viewForms.style.display !== 'none') {
      loadHistory(user.uid);
    }
  });

  // ── Form history ─────────────────────────────────────────────────────────────
  const historyList = document.getElementById('history-list')!;

  function esc(s: string) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  async function loadHistory(userId: string) {
    historyList.innerHTML = `
      <div class="history-spinner">
        <svg viewBox="0 0 50 50" class="spinner-svg">
          <circle cx="25" cy="25" r="20" fill="none" stroke="#E5E7EB" stroke-width="4"/>
          <circle cx="25" cy="25" r="20" fill="none" stroke="url(#sg)" stroke-width="4"
            stroke-linecap="round" stroke-dasharray="80" stroke-dashoffset="60"/>
          <defs>
            <linearGradient id="sg" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#5B2D9E"/>
              <stop offset="100%" stop-color="#C848FF"/>
            </linearGradient>
          </defs>
        </svg>
      </div>`;
    try {
      const snap = await getDocs(query(collection(db, 'forms'), where('userId', '==', userId)));
      if (snap.empty) {
        historyList.innerHTML = `<p class="panel-empty">${t('panel.empty')}</p>`;
        return;
      }
      const lang = (window as any).__lang || 'es';
      const docs = [...snap.docs].sort((a, b) =>
        b.data().createdAt.localeCompare(a.data().createdAt)
      );
      historyList.innerHTML = docs.map(doc => {
        const d = doc.data();
        const date = new Date(d.createdAt).toLocaleDateString(lang === 'en' ? 'en-US' : 'es-ES', {
          day: 'numeric', month: 'short', year: 'numeric',
        });
        return `
          <div class="history-card">
            <div>
              <div class="history-card-title">${esc(d.title)}</div>
              <div class="history-card-date">${date}</div>
            </div>
            <div class="history-card-actions">
              <a href="${esc(d.formUrl)}" target="_blank" rel="noopener" class="hbtn hbtn--primary">${t('panel.form.open')}</a>
              <a href="${esc(d.editUrl)}" target="_blank" rel="noopener" class="hbtn hbtn--secondary">${t('panel.form.edit')}</a>
            </div>
          </div>`;
      }).join('');
    } catch {
      historyList.innerHTML = `<p class="panel-empty">${t('panel.load.error')}</p>`;
    }
  }

  // ── Incidencias ───────────────────────────────────────────────────────────────
  const textarea  = document.getElementById('inc-desc')    as HTMLTextAreaElement;
  const submitBtn = document.getElementById('inc-submit')  as HTMLButtonElement;
  const msgEl     = document.getElementById('inc-msg')!;
  const charsEl   = document.getElementById('inc-chars')!;

  textarea?.addEventListener('input', () => {
    charsEl.textContent = `${textarea.value.length} / 2000`;
  });

  submitBtn?.addEventListener('click', async () => {
    const desc = textarea.value.trim();
    if (!desc) { showMsg(t('panel.report.empty'), 'error'); return; }

    submitBtn.disabled = true;
    submitBtn.textContent = t('panel.report.sending');
    msgEl.style.display = 'none';

    try {
      await addDoc(collection(db, 'incidencias'), {
        userId:      auth.currentUser?.uid ?? null,
        description: desc,
        createdAt:   new Date().toISOString(),
        status:      'open',
      });
      textarea.value = '';
      charsEl.textContent = '0 / 2000';
      showMsg(t('panel.report.ok'), 'ok');
    } catch {
      showMsg(t('panel.report.err'), 'error');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = t('panel.report.btn');
    }
  });

  function showMsg(text: string, type: 'ok' | 'error') {
    msgEl.textContent = text;
    msgEl.className = `inc-msg inc-msg--${type}`;
    msgEl.style.display = 'block';
  }
</script>
