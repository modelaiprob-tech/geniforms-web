---
import SEO from '../components/common/SEO.astro';
import CookieBanner from '../components/common/CookieBanner.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <SEO title={title} description={description} ogImage={ogImage} />

  <!-- i18n: establece data-lang antes del paint para evitar flash -->
