rgar Google Picker. Comprueba que la API esté habilitada.","err.file":"No se pudo leer el archivo","err.generate":"Error al generar el formulario"},en:{"nav.signin":"Sign in","nav.forms":"My forms","nav.report":"Report a problem","nav.signout":"Sign out","hero.1":"Generate quizzes","hero.2":"in seconds with AI","s1.title":"How do you want to create your quiz?","mode.gen.title":"Generate from scratch","mode.gen.desc":"AI designs questions based on your subject and teaching goals","mode.fmt.title":"I already have the quiz written","mode.fmt.desc":"Paste your text or upload a file to convert it into a form","tip.title":"Teaching tip","tip.text":"Define the level and subject clearly to get more precise questions aligned with your curriculum.","s2a.title":"Tell us about your quiz.","lbl.formtitle":"Form title *","lbl.subject":"Subject *","lbl.context":"Additional context","lbl.refmat":"Reference material","tab.paste":"Paste text","tab.drive":"From Drive","btn.pickfile":"Select file from Drive","btn.changefile":"Change file","lbl.intro":"Introduction (optional)","lbl.diff":"Difficulty","diff.easy":"Easy","diff.med":"Medium","diff.hard":"Hard","s2b.title":"Paste your quiz here.","lbl.quiztext":"Quiz text","upload.title":"Drag or click to upload","upload.sub":".txt · .pdf · .docx — max 10 MB","upload.warn":"Only .txt files in this version. For .pdf and .docx, copy the text and paste it above.","tip.sol.text":"If you have the answer key, paste it below. AI will assign correct answers more accurately.","lbl.sol":"Do you have the answer key? (optional)","s3.title":"Configure your questions.","type.mc":"Multiple choice (ABCD)","type.vf":"True / False","type.short":"Short answer","type.cb":"Checkboxes (multi-answer)","total.suffix":"questions","warn.short":"Short answer questions cannot be auto-graded in Google Forms.","keepasis.title":"You have pasted text","keepasis.text":"You can configure the types above, or let AI detect types and answers directly from your text.","btn.keepasis":"Keep as is","s4.title":"Where should we save the form?","btn.pickfolder":"Select folder in Drive","folder.default":"My Drive (root)","toggle.sol.label":"Generate answer key","toggle.sol.sub":"Download with detailed explanations","btn.create":"Create form","loading.1":"Generating your quiz...","loading.2":"Applying artificial intelligence...","loading.3":"Almost ready...","loading.tip.1":"The more specific the topic, the better the result.","loading.tip.2":"Multiple choice questions favor objective evaluation.","loading.tip.3":"The difficulty level affects the complexity of vocabulary used.","suc.title":"Form created","suc.name":"Name","suc.count.suffix":"questions","suc.folder.key":"Drive folder","btn.openform":"Open form","btn.editform":"Edit form","btn.restart":"Create another form","modal.title":"Sign in to continue","modal.text":"Connect your Google account to generate quizzes and save them to your Drive.","modal.btn":"Continue with Google","btn.back":"Back","btn.next":"Next","login.title":"Sign in","login.sub":"Connect your Google account to generate quizzes and save them to your Drive.","login.btn":"Continue with Google","login.connecting":"Connecting...","login.error":"Sign-in error. Please try again.","panel.forms":"My forms","panel.report":"Report a problem","panel.empty":"You haven't created any forms yet.","panel.load.error":"Error loading history.","panel.form.open":"Open","panel.form.edit":"Edit","panel.report.desc":"Describe the problem you found and we'll reply by email.","panel.report.ph":"Describe the problem...","panel.report.btn":"Send report","panel.report.sending":"Sending...","panel.report.ok":"Report sent. Thank you.","panel.report.err":"Error sending. Please try again.","panel.report.empty":"Write a description before sending.","err.picker":"Error loading Google Picker. Make sure the API is enabled.","err.file":"Could not read the file","err.generate":"Error generating the form"}};
    var l=localStorage.getItem('gf_lang')||'es';
    document.documentElement.setAttribute('data-lang',l);
    document.documentElement.lang=l;
    window.__lang=l;
    window.__t=function(k){return(T[l]&&T[l][k])||k;};
    window.__setLang=function(nl){
      l=nl; localStorage.setItem('gf_lang',nl);
      document.documentElement.setAttribute('data-lang',nl);
      document.documentElement.lang=nl;
      window.__lang=nl;
      window.__t=function(k){return(T[nl]&&T[nl][k])||k;};
      document.querySelectorAll('[data-i18n]').forEach(function(el){
        var k=el.getAttribute('data-i18n');
        if(T[nl]&&T[nl][k])el.textContent=T[nl][k];
      });
      document.querySelectorAll('[data-i18n-ph]').forEach(function(el){
        var k=el.getAttribute('data-i18n-ph');
        if(T[nl]&&T[nl][k])el.placeholder=T[nl][k];
      });
      document.dispatchEvent(new CustomEvent('gf:lang-changed',{detail:{lang:nl}}));
    };
    document.addEventListener('DOMContentLoaded',function(){window.__setLang(l);});
  })();
  </script>

  <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />
  <link rel="apple-touch-icon" href="/favicon-512.png" />
  <link rel="shortcut icon" href="/favicon-512.png" />

  <style>
    /* ── TOKENS ── */
    :root {
      --accent:    #5B2D9E;
      --cyan:      #00D4FF;
      --magenta:   #C848FF;
      --text:      #1A1A2E;
      --text-2:    #6B7280;
      --card:      #FFFFFF;
      --bg:        #F5F5F5;
      --border:    #E5E7EB;
      --radius-lg: 16px;
      --radius-md: 10px;
      --radius-sm: 6px;
      --font:      system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
      --shadow-card: 0 2px 8px rgba(91,45,158,0.07);
      --shadow-md:   0 4px 20px rgba(91,45,158,0.12);
    }

    /* ── RESET ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html {
      scroll-behavior: smooth;
      font-family: var(--font);
      font-size: 14px;
      color: var(--text);
      background: var(--bg);
      -webkit-font-smoothing: antialiased;
    }

    body { min-height: 100vh; display: flex; flex-direction: column; }

    a { color: inherit; text-decoration: none; }

    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(91,45,158,0.2); border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: rgba(91,45,158,0.4); }
  </style>
</head>
<body>
  <slot />
  <CookieBanner />
  <script>
    // Refresca el Firebase ID token en la cookie en cada carga de página,
    // para que el servidor siempre vea un token válido.
    import { auth } from '../lib/firebase';
    import { onAuthStateChanged } from 'firebase/auth';

    onAuthStateChanged(auth, async (user) => {
      if (user) {
        const idToken = await user.getIdToken();
        document.cookie = `gf_firebase_token=${idToken}; path=/; max-age=3600; SameSite=Strict`;
      }
    });
  </script>
</body>
</html>
