---
import Base from '../../layouts/Base.astro';
---

<Base title="Iniciar sesión — Geniforms">
  <div class="login-wrap">
    <div class="login-card">
      <img src="/images/sidebar-logo.png" alt="Geniforms" class="login-logo" />
      <h1 class="login-title">Inicia sesión</h1>
      <p class="login-sub">Conecta tu cuenta de Google para generar cuestionarios y guardarlos en tu Drive.</p>
      <button id="btn-google" class="btn-google">
        <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
          <path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.874 2.684-6.615z"/>
          <path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.184l-2.908-2.258c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 009 18z"/>
          <path fill="#FBBC05" d="M3.964 10.707A5.41 5.41 0 013.682 9c0-.593.102-1.17.282-1.707V4.961H.957A8.996 8.996 0 000 9c0 1.452.348 2.827.957 4.039l3.007-2.332z"/>
          <path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 00.957 4.961L3.964 6.293C4.672 4.166 6.656 3.58 9 3.58z"/>
        </svg>
        Continuar con Google
      </button>
      <p id="login-error" class="login-error hidden"></p>
    </div>
  </div>
</Base>

<style>
  .login-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    min-height: 100vh;
  }
  .login-card {
    background: var(--card);
    border-radius: var(--radius-lg);
    padding: 40px 32px;
    width: 100%;
    max-width: 380px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    box-shadow: var(--shadow-md);
    text-align: center;
  }
  .login-logo {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    object-fit: contain;
  }
  .login-title {
    font-size: 22px;
    font-weight: 800;
    color: var(--text);
  }
  .login-sub {
    font-size: 14px;
    color: var(--text-2);
    line-height: 1.5;
    max-width: 280px;
  }
  .btn-google {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 12px;
    background: var(--card);
    border: 1.5px solid var(--border);
    border-radius: var(--radius-md);
    font-family: var(--font);
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    cursor: pointer;
    transition: border-color 0.15s, box-shadow 0.15s;
    margin-top: 8px;
  }
  .btn-google:hover   { border-color: var(--accent); box-shadow: 0 2px 8px rgba(91,45,158,0.12); }
  .btn-google:disabled { opacity: 0.5; cursor: not-allowed; }
  .login-error { font-size: 13px; color: #DC2626; line-height: 1.4; }
  .hidden { display: none; }
</style>

<script>
  import { signInWithPopup, GoogleAuthProvider } from 'firebase/auth';
  import { doc, setDoc } from 'firebase/firestore';
  import { auth, db, googleProvider } from '../../lib/firebase';

  const btn      = document.getElementById('btn-google') as HTMLButtonElement;
  const errEl    = document.getElementById('login-error')!;
  const googleIconSvg = btn.querySelector('svg')!.outerHTML;

  btn.addEventListener('click', async () => {
    btn.disabled = true;
    btn.textContent = 'Conectando...';
    errEl.classList.add('hidden');

    try {
      const result     = await signInWithPopup(auth, googleProvider);
      const credential = GoogleAuthProvider.credentialFromResult(result)!;

      localStorage.setItem('gf_google_token', credential.accessToken!);

      const idToken = await result.user.getIdToken();
      document.cookie = `gf_firebase_token=${idToken}; path=/; max-age=3600; SameSite=Strict`;

      await setDoc(doc(db, 'users', result.user.uid), {
        id:         result.user.uid,
        email:      result.user.email,
        name:       result.user.displayName,
        avatar:     result.user.photoURL,
        updated_at: new Date().toISOString(),
      }, { merge: true });

      window.location.href = '/';
    } catch {
      errEl.textContent = 'Error al iniciar sesión. Inténtalo de nuevo.';
      errEl.classList.remove('hidden');
      btn.disabled = false;
      btn.innerHTML = `${googleIconSvg} Continuar con Google`;
    }
  });
</script>
