---
import Base from '../../layouts/Base.astro';
---

<Base title="Geniforms — Acción de cuenta">
  <div class="action-wrap">
    <div class="action-card" id="action-card">
      <img src="/images/sidebar-logo.png" alt="Geniforms" class="action-logo" />

      <!-- Estado: cargando -->
      <div id="state-loading">
        <svg viewBox="0 0 50 50" width="40" height="40" style="animation:spin 0.9s linear infinite;display:block;margin:0 auto 16px">
          <circle cx="25" cy="25" r="20" fill="none" stroke="#E5E7EB" stroke-width="4"/>
          <circle cx="25" cy="25" r="20" fill="none" stroke="url(#ag)" stroke-width="4"
            stroke-linecap="round" stroke-dasharray="80" stroke-dashoffset="60"/>
          <defs>
            <linearGradient id="ag" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#5B2D9E"/>
              <stop offset="100%" stop-color="#C848FF"/>
            </linearGradient>
          </defs>
        </svg>
        <p class="action-sub">Procesando...</p>
      </div>

      <!-- Estado: verificación de email OK -->
      <div id="state-verify-ok" class="hidden">
        <div class="action-icon action-icon--ok">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </div>
        <h1 class="action-title">Email verificado</h1>
        <p class="action-sub">Tu dirección de correo ha sido confirmada correctamente.</p>
        <a href="/" class="btn-action">Ir a Geniforms</a>
      </div>

      <!-- Estado: resetear contraseña (formulario) -->
      <div id="state-reset-form" class="hidden">
        <div class="action-icon action-icon--purple">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#5B2D9E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
        </div>
        <h1 class="action-title">Nueva contraseña</h1>
        <p class="action-sub">Escribe tu nueva contraseña para <strong id="reset-email"></strong></p>
        <div class="field-group">
          <input type="password" id="inp-password" class="action-input" placeholder="Nueva contraseña" autocomplete="new-password" />
          <input type="password" id="inp-password2" class="action-input" placeholder="Repetir contraseña" autocomplete="new-password" />
        </div>
        <button id="btn-reset" class="btn-action">Guardar contraseña</button>
        <p id="reset-error" class="action-error hidden"></p>
      </div>

      <!-- Estado: contraseña cambiada OK -->
      <div id="state-reset-ok" class="hidden">
        <div class="action-icon action-icon--ok">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </div>
        <h1 class="action-title">Contraseña actualizada</h1>
        <p class="action-sub">Ya puedes iniciar sesión con tu nueva contraseña.</p>
        <a href="/auth/login" class="btn-action">Iniciar sesión</a>
      </div>

      <!-- Estado: error -->
      <div id="state-error" class="hidden">
        <div class="action-icon action-icon--err">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <line x1="15" y1="9" x2="9" y2="15"/>
            <line x1="9" y1="9" x2="15" y2="15"/>
          </svg>
        </div>
        <h1 class="action-title">Enlace inválido</h1>
        <p id="error-msg" class="action-sub">El enlace ha expirado o ya fue utilizado.</p>
        <a href="/" class="btn-action btn-action--secondary">Volver al inicio</a>
      </div>
    </div>
  </div>
</Base>

<style>
  @keyframes spin { to { transform: rotate(360deg); } }

  .action-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    min-height: 100vh;
  }

  .action-card {
    background: var(--card);
    border-radius: var(--radius-lg);
    padding: 40px 32px;
    width: 100%;
    max-width: 400px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    box-shadow: var(--shadow-md);
    text-align: center;
  }

  .action-logo {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    object-fit: contain;
    margin-bottom: 4px;
  }

  .action-icon {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .action-icon--ok     { background: #DCFCE7; }
  .action-icon--purple { background: #EDE8FA; }
  .action-icon--err    { background: #FEE2E2; }

  .action-title {
    font-size: 20px;
    font-weight: 800;
    color: var(--text);
    margin: 0;
  }

  .action-sub {
    font-size: 14px;
    color: var(--text-2);
    line-height: 1.5;
    margin: 0;
    max-width: 300px;
  }

  .field-group {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .action-input {
    width: 100%;
    padding: 11px 14px;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-md);
    font-family: var(--font);
    font-size: 14px;
    color: var(--text);
    background: var(--bg);
    outline: none;
    transition: border-color 0.15s;
    box-sizing: border-box;
  }
  .action-input:focus { border-color: var(--accent); }

  .btn-action {
    width: 100%;
    padding: 12px;
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    font-family: var(--font);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: opacity 0.15s;
    box-sizing: border-box;
  }
  .btn-action:hover    { opacity: 0.88; }
  .btn-action:disabled { opacity: 0.45; cursor: not-allowed; }
  .btn-action--secondary {
    background: none;
    border: 1.5px solid var(--border);
    color: var(--text-2);
  }
  .btn-action--secondary:hover { border-color: var(--accent); color: var(--accent); opacity: 1; }

  .action-error {
    font-size: 13px;
    color: #DC2626;
    margin: 0;
  }

  .hidden { display: none !important; }
</style>

<script>
  import {
    getAuth,
    applyActionCode,
    verifyPasswordResetCode,
    confirmPasswordReset,
  } from 'firebase/auth';
  import { auth } from '../../lib/firebase';

  const params   = new URLSearchParams(window.location.search);
  const mode     = params.get('mode');
  const oobCode  = params.get('oobCode') ?? '';

  function show(id: string) {
    const ids = ['state-loading','state-verify-ok','state-reset-form','state-reset-ok','state-error'];
    ids.forEach(i => document.getElementById(i)!.classList.add('hidden'));
    document.getElementById(id)!.classList.remove('hidden');
  }

  function showError(msg?: string) {
    if (msg) document.getElementById('error-msg')!.textContent = msg;
    show('state-error');
  }

  async function init() {
    if (!mode || !oobCode) { showError('Faltan parámetros en el enlace.'); return; }

    if (mode === 'verifyEmail' || mode === 'recoverEmail') {
      try {
        await applyActionCode(auth, oobCode);
        show('state-verify-ok');
      } catch (e: any) {
        showError(e.code === 'auth/invalid-action-code'
          ? 'El enlace ya fue utilizado o ha expirado.'
          : 'No se pudo verificar el email.');
      }

    } else if (mode === 'resetPassword') {
      try {
        const email = await verifyPasswordResetCode(auth, oobCode);
        document.getElementById('reset-email')!.textContent = email;
        show('state-reset-form');

        document.getElementById('btn-reset')!.addEventListener('click', async () => {
          const btn = document.getElementById('btn-reset') as HTMLButtonElement;
          const p1  = (document.getElementById('inp-password')  as HTMLInputElement).value;
          const p2  = (document.getElementById('inp-password2') as HTMLInputElement).value;
          const err = document.getElementById('reset-error')!;

          if (p1.length < 6) { err.textContent = 'La contraseña debe tener al menos 6 caracteres.'; err.classList.remove('hidden'); return; }
          if (p1 !== p2)     { err.textContent = 'Las contraseñas no coinciden.'; err.classList.remove('hidden'); return; }

          btn.disabled = true;
          btn.textContent = 'Guardando...';
          err.classList.add('hidden');

          try {
            await confirmPasswordReset(auth, oobCode, p1);
            show('state-reset-ok');
          } catch {
            btn.disabled = false;
            btn.textContent = 'Guardar contraseña';
            err.textContent = 'Error al cambiar la contraseña. El enlace puede haber expirado.';
            err.classList.remove('hidden');
          }
        });

      } catch {
        showError('El enlace de restablecimiento ha expirado o ya fue utilizado.');
      }

    } else {
      showError(`Acción desconocida: ${mode}`);
    }
  }

  init();
</script>
